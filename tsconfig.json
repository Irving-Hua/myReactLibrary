{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "@xui/base": ["packages/base/src/index.ts"],
      "@xui/fields": ["packages/fields/src/index.ts"],
      "@xui/input": ["packages/input/src/index.ts"],
      "@xui/types": ["packages/types/src/index.ts"],
      "@xui/utils": ["packages/utils/src/index.ts"]
    }
  },
  "include": [".dumirc.ts", "packages/*/src/**/*", "packages/*/.fatherrc.ts"]
}
